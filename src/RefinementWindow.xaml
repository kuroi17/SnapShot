<Window x:Class="SnapShot.RefinementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Capture"
        Width="520"
        Height="620"
        MinWidth="400"
        MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Background="#D4D0C8"
        WindowStyle="ThreeDBorderWindow"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Classic Windows 95 Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#D4D0C8"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontFamily" Value="MS Sans Serif, Tahoma, Arial"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Width" Value="85"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Outer bevel (white on top-left, dark-gray on bottom-right) -->
                        <Border x:Name="OuterBorder" BorderBrush="#FFFFFF" BorderThickness="1,1,0,0" SnapsToDevicePixels="True">
                            <Border x:Name="InnerBorder" BorderBrush="#808080" BorderThickness="0,0,1,1">
                                <!-- Inner bevel shadow (light-gray on top-left, black on bottom-right) -->
                                <Border x:Name="ShadowBorder" BorderBrush="#D4D0C8" BorderThickness="1,1,0,0">
                                    <Border x:Name="BlackBorder" BorderBrush="#404040" BorderThickness="0,0,1,1" Background="{TemplateBinding Background}" Padding="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#808080"/>
                                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter TargetName="ShadowBorder" Property="BorderBrush" Value="#404040"/>
                                <Setter TargetName="BlackBorder" Property="BorderBrush" Value="#D4D0C8"/>
                                <Setter TargetName="BlackBorder" Property="Padding" Value="3,3,1,1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#808080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Classic Windows 95 CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="MS Sans Serif, Tahoma, Arial"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Sunken square for checkmark -->
                            <Border BorderBrush="#808080" BorderThickness="1,1,0,0" Width="13" Height="13" SnapsToDevicePixels="True" Background="#FFFFFF">
                                <Border BorderBrush="#000000" BorderThickness="1,1,0,0">
                                    <Border BorderBrush="#FFFFFF" BorderThickness="0,0,1,1">
                                        <Border BorderBrush="#D4D0C8" BorderThickness="0,0,1,1">
                                            <Grid>
                                                <!-- Classic pixelated checkmark -->
                                                <Path x:Name="CheckMark"
                                                      Data="M 2,4 L 4,6 L 9,1 L 9,2.5 L 4,7.5 L 2,5.5 Z"
                                                      Fill="#000000"
                                                      Visibility="Collapsed"
                                                      Stretch="Fill"
                                                      Margin="1"/>
                                            </Grid>
                                        </Border>
                                    </Border>
                                </Border>
                            </Border>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>      <!-- Image preview -->
            <RowDefinition Height="Auto"/>   <!-- Control GroupBox -->
            <RowDefinition Height="Auto"/>   <!-- Action Buttons -->
        </Grid.RowDefinitions>

        <!-- 1. Sunken Image Preview Box with Floating Background Selectors -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Border BorderBrush="#808080" BorderThickness="1,1,0,0" SnapsToDevicePixels="True">
                <Border BorderBrush="#000000" BorderThickness="1,1,0,0">
                    <Border BorderBrush="#FFFFFF" BorderThickness="0,0,1,1">
                        <Border BorderBrush="#D4D0C8" BorderThickness="0,0,1,1">
                            <!-- Scrollable Checkerboard container -->
                            <ScrollViewer x:Name="ImageScrollViewer" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"
                                          Focusable="False" 
                                          PanningMode="Both"
                                          PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                                          MouseDown="ImageScrollViewer_MouseDown"
                                          MouseMove="ImageScrollViewer_MouseMove"
                                          MouseUp="ImageScrollViewer_MouseUp">
                                <ScrollViewer.Background>
                                    <DrawingBrush TileMode="Tile" Viewport="0,0,16,16" ViewportUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <DrawingGroup>
                                                <GeometryDrawing Brush="#FFFFFF">
                                                    <GeometryDrawing.Geometry>
                                                        <RectangleGeometry Rect="0,0,16,16"/>
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <GeometryDrawing Brush="#E0E0E0">
                                                    <GeometryDrawing.Geometry>
                                                        <GeometryGroup>
                                                            <RectangleGeometry Rect="0,0,8,8"/>
                                                            <RectangleGeometry Rect="8,8,8,8"/>
                                                        </GeometryGroup>
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingGroup>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </ScrollViewer.Background>

                                <Grid x:Name="ImageContainerGrid" RenderTransformOrigin="0.5,0.5">
                                    <Grid.LayoutTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1.0" ScaleY="1.0"/>
                                        </TransformGroup>
                                    </Grid.LayoutTransform>

                                    <Image x:Name="BackgroundOriginalImage" Stretch="Uniform" Margin="10" Opacity="0.6" Visibility="Collapsed"/>
                                    <Image x:Name="PreviewImage" Stretch="Uniform" Margin="10" RenderOptions.BitmapScalingMode="HighQuality"
                                           MouseDown="PreviewImage_MouseDown" MouseMove="PreviewImage_MouseMove" MouseUp="PreviewImage_MouseUp"/>
                                </Grid>
                            </ScrollViewer>
                        </Border>
                    </Border>
                </Border>
            </Border>

            <!-- Floating Window 95 Background Selectors in Top Right -->
            <Border BorderBrush="#FFFFFF" BorderThickness="1,1,0,0" Background="#D4D0C8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6" SnapsToDevicePixels="True" Panel.ZIndex="10">
                <Border BorderBrush="#808080" BorderThickness="0,0,1,1" Padding="3">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BgGridButton" Content="🏁" Width="22" Height="22" Click="BgGridButton_Click" Margin="0,0,3,0"/>
                        <Button x:Name="BgWhiteButton" Content="⬜" Width="22" Height="22" Click="BgWhiteButton_Click" Margin="0,0,3,0"/>
                        <Button x:Name="BgBlackButton" Content="⬛" Width="22" Height="22" Click="BgBlackButton_Click"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <!-- 2. Retro GroupBox / Frame for Settings -->
        <Border Grid.Row="1" BorderBrush="#808080" BorderThickness="1,1,0,0" SnapsToDevicePixels="True" Margin="0,0,0,12">
            <Border BorderBrush="#FFFFFF" BorderThickness="0,0,1,1" Padding="10">
                <StackPanel>
                    <TextBlock Text="Refinement Settings" FontWeight="Bold" FontFamily="MS Sans Serif, Tahoma" FontSize="11" Margin="0,0,0,10"/>
                    
                    <CheckBox x:Name="RemoveBgCheckBox" Content="Remove Background" IsChecked="True" Checked="RemoveBgCheckBox_Changed" Unchecked="RemoveBgCheckBox_Changed" Margin="0,0,0,10"/>

                    <Grid x:Name="SliderContainer" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Keep Object" FontFamily="MS Sans Serif, Tahoma" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Grid.Column="1" x:Name="ThresholdSlider" Minimum="0.10" Maximum="0.90" Value="0.48" 
                                TickFrequency="0.05" IsSnapToTickEnabled="False"
                                ValueChanged="ThresholdSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Clean Background" FontFamily="MS Sans Serif, Tahoma" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox x:Name="RestoreBrushCheckBox" Content="Restore Brush" IsChecked="False" Checked="RestoreBrushCheckBox_Changed" Unchecked="RestoreBrushCheckBox_Changed" Margin="0,0,20,0"/>
                        <CheckBox x:Name="RemoveBrushCheckBox" Content="Remove Brush" IsChecked="False" Checked="RemoveBrushCheckBox_Changed" Unchecked="RemoveBrushCheckBox_Changed"/>
                    </StackPanel>

                    <Grid x:Name="BrushSizeContainer" Margin="0,0,0,5" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Brush Size" FontFamily="MS Sans Serif, Tahoma" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Grid.Column="1" x:Name="BrushSizeSlider" Minimum="1" Maximum="60" Value="10" 
                                TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="BrushSizeSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="BrushSizeText" Text="10 px" FontFamily="MS Sans Serif, Tahoma" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0" Width="40"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- 3. Action Buttons (Undo, Redo, Okay) -->
        <Grid Grid.Row="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="UndoButton" Content="Undo" Click="UndoButton_Click" Margin="0,0,8,0" IsEnabled="False"/>
                <Button x:Name="RedoButton" Content="Redo" Click="RedoButton_Click" IsEnabled="False"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Okay" IsDefault="True" Click="OkayButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
