<Window x:Class="SnapShot.CaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SnapShot Capture"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="Window_KeyDown">

    <Grid>
        <!-- Dark overlay covering entire screen -->
        <Canvas x:Name="OverlayCanvas"
                Background="#80000000"
                MouseDown="Canvas_MouseDown"
                MouseMove="Canvas_MouseMove"
                MouseUp="Canvas_MouseUp">

            <!-- Selection rectangle (drawn programmatically) -->
            <Rectangle x:Name="SelectionRect"
                       Stroke="#00D4FF"
                       StrokeThickness="1.5"
                       Fill="#20FFFFFF"
                       Visibility="Collapsed" />

            <!-- Dimension label -->
            <Border x:Name="DimLabel"
                    Background="#CC000000"
                    CornerRadius="3"
                    Padding="6,3"
                    Visibility="Collapsed">
                <TextBlock x:Name="DimText"
                           Foreground="#00D4FF"
                           FontFamily="Consolas"
                           FontSize="11" />
            </Border>

            <!-- Instruction hint (shown before drag starts) -->
            <StackPanel x:Name="HintPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False">
                <Border Background="#CC000000" CornerRadius="8" Padding="20,12">
                    <StackPanel>
                        <TextBlock Text="Drag to select a region"
                                   Foreground="White"
                                   FontSize="16"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="ESC to cancel"
                                   Foreground="#80FFFFFF"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

        </Canvas>
    </Grid>
</Window>
